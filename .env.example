# --- Database -------------------------------------------------------------
# Local development points at the Postgres container from docker-compose.yml.
# In production (Vercel/Render/Railway) set this to the managed Postgres URL.
DATABASE_URL="postgresql://hcedp:hcedp_local_dev@localhost:5432/hcedp?schema=public"

# --- Anthropic API --------------------------------------------------------
# Required for RFI intake parsing. Never commit a real key.
ANTHROPIC_API_KEY=""

# Model used for routine RFI parsing. Single config value, easy to change.
ANTHROPIC_MODEL="claude-sonnet-4-6"
# Optional higher-capability model for difficult documents (used when the
# intake request sets useHighEffortModel=true).
ANTHROPIC_MODEL_HIGH_EFFORT="claude-opus-4-8"

# --- File storage ---------------------------------------------------------
# "local" writes uploads to STORAGE_LOCAL_DIR. Swap for "s3"/"blob" later
# by adding an implementation in src/lib/storage without touching features.
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage-uploads"

# --- Authentication -------------------------------------------------------
# The app uses multi-user login with roles. This bootstrap admin account is
# (re)created from these two variables every time the server starts, so the
# master login always lives in the host environment (Railway). If you ever get
# locked out, change these and redeploy. All other users are created in-app by
# an admin (Users page). Setting a new ADMIN_PASSWORD here rotates the admin's
# password on the next deploy.
ADMIN_EMAIL="you@hayscaldwelledp.com"
ADMIN_PASSWORD="change-me-to-something-strong"
